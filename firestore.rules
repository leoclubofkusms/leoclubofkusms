rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Read access: Allow everyone to read
    match /{document=**} {
      allow read: if true;
    }
    
    // Write access: Only authenticated admin
    match /members/{document} {
      allow write: if request.auth != null && 
        request.auth.email == 'admin@kusmsleoclub.com';
    }
    
    match /activities/{document} {
      allow write: if request.auth != null && 
        request.auth.email == 'admin@kusmsleoclub.com';
    }
  }
}
